rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /dogs/{dogId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid in resource.data.humanIds;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.humanIds;
    }

    match /humans/{humanId} {
      allow read, create, delete: if request.auth != null && request.auth.uid == humanId;
      allow update: if request.auth != null
        && (request.auth.uid == humanId
          || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['unreadCounts']));
    }

    match /packLinks/{linkId} {
      allow read, write: if request.auth != null;
    }

    match /packRequests/{reqId} {
      allow read, write: if request.auth != null;
    }

    match /alerts/{alertId} {
      allow read, write: if request.auth != null;
    }

    match /conversations/{conversationId} {
      allow read: if request.auth != null
        && (resource == null || request.auth.uid in resource.data.humanIds);
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.humanIds;
      allow update: if request.auth != null
        && request.auth.uid in resource.data.humanIds;

      match /messages/{messageId} {
        allow read, create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.humanIds;
        allow update: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.humanIds
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readAt']);
      }
    }

  }
}
